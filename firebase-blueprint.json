{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "tier": { "type": "string", "enum": ["Free", "Pro", "Plus"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat conversation session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "title", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message within a chat session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["sessionId", "userId", "role", "text", "createdAt"]
    },
    "GeneratedImage": {
      "title": "GeneratedImage",
      "description": "An image generated by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "url": { "type": "string" },
        "prompt": { "type": "string" },
        "aspectRatio": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "url", "prompt", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "User chat sessions"
    },
    "users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages in a session"
    },
    "users/{userId}/history/{imageId}": {
      "schema": "GeneratedImage",
      "description": "User generation history"
    }
  }
}
